# ═══════════════════════════════════════════════════════════════════
#  QuantumEnergyOS — Environment Configuration
#  Copia este archivo a .env y configura tus tokens
# ═══════════════════════════════════════════════════════════════════

# ── IBM Quantum ─────────────────────────────────────────────────────
# Obtén tu token en: https://quantum.ibm.com/account
# Exporta: export IBM_QUANTUM_TOKEN="tu-token-aqui"
IBM_QUANTUM_TOKEN=your_ibm_quantum_token_here

# ── Azure Quantum ────────────────────────────────────────────────────
# Obtén tu token en: https://portal.azure.com/quantum
# Exporta: export AZURE_QUANTUM_TOKEN="tu-token-aqui"
AZURE_QUANTUM_TOKEN=your_azure_quantum_token_here

# ── Server Configuration ─────────────────────────────────────────────
PORT=8000
QEOS_ENV=development

# ── Qiskit Configuration ─────────────────────────────────────────────
QISKIT_AER_BACKEND=aer_simulator
QISKIT_NOISE_MODEL=false

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO